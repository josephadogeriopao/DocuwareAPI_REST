{
  "ConnectionStrings": {
    "OracleDbConnection": "Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST={0})(PORT={1}))(CONNECT_DATA=(SID={2})));User Id={3};Password={4};"
  },
  "ORACLE_HOST": "placeholder",
  "ORACLE_PORT": "1521",
  "ORACLE_SID": "placeholder",
  "ORACLE_USERNAME": "placeholder",
  "ORACLE_PASSWORD": "placeholder",
  "IAS_USERNAME": "placeholder",
  "IAS_PASSWORD": "placeholder",
  "IAS_TRANS_NAME": "placeholder",
  "IAS_JUR": "placeholder",
  "IAS_SUBMIT_MODE": "Save",
  "IAS_ENDPOINT_ADDRESS": "placeholder",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/api-log-.json",
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog",
          "rollingInterval": "Day"
        }
      }
    ],
    "Properties": {
      "Application": "OPAOWebService"
    }
  },
  "DataProtection": {
    "KeyPath": "C:\\Keys\\OPAORestWebService\\"
  }
}
